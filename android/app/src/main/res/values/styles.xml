<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Shown briefly while the Android window initializes, before Flutter
         draws its first frame. Uses the Aero Glass blue gradient so there is
         no white/black flash before the app's own background takes over. -->
    <style name="LaunchTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Used by the Flutter engine after the first frame is drawn. -->
    <style name="NormalTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
